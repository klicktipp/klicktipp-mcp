# Runtime
KT_BASE_URL=https://api.klicktipp.com
KT_TIMEOUT_MS=30000
KT_TOOL_MODE=readonly
KT_ENABLE_WRITES=false
KT_ENABLE_DESTRUCTIVE=false
KT_AUDIT_LOGS=true

# Auth mode:
# - partner: recommended for long-lived/customer-facing integrations
# - session: supported fallback for internal/test usage
KT_AUTH_MODE=session

# Shared
KT_USERNAME=

# Session auth
KT_PASSWORD=

# Partner auth
# Developer key must be a hex string.
KT_DEVELOPER_KEY=
KT_CUSTOMER_KEY=

# Optional helper value for building the customer grant URL in your own app:
KT_ACCOUNT_ID=
