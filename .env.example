# Basic configuration:
KT_BASE_URL=https://api.klicktipp.com
KT_TIMEOUT_MS=30000
KT_AUDIT_LOGS=true

# Access configuration:
# KT_TOOL_MODE controls which tool set is exposed by the MCP server.
# - readonly: Safe default. Only read-only tools are available.
# - full: Enables write-capable tools, but only when KT_ENABLE_WRITES=true.
# Set KT_ENABLE_DESTRUCTIVE=true only if you also want delete/destructive actions.
KT_TOOL_MODE=readonly
KT_ENABLE_WRITES=false
KT_ENABLE_DESTRUCTIVE=false

# Auth mode:
# - session: Session Auth mode supported fallback for internal/test usage
# - partner: Partner Auth mode recommended for long-lived/customer-facing integrations
KT_AUTH_MODE=session

# Shared Auth mode: 
KT_USERNAME=

# Session Auth mode:
KT_PASSWORD=

# Partner Auth mode: 
# Developer key must be a hex string.
KT_DEVELOPER_KEY=
KT_CUSTOMER_KEY=

# Optional helper value for building the customer grant URL in your own app:
KT_ACCOUNT_ID=
